// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// enum
enum UserRole { 
  USER 
  ADMIN 
}

enum ApproveStatus {
  APPROVE
  PENDING
  REJECT
}

enum HistoryStatus {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
}

enum EntityType {
  EQUIPMENT
  REQUEST
  USER
}

enum AuctionMethod {
  PUBLIC_VERBAL
  SPECIFIC
  E_BIDDING
  OTHER
}

enum EquipmentStatus {
  IN_USE
  BROKEN
  MAINTENANCE
  DISPOSED
}

// model
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  equipments Equipment[]
  
  @@map("categories")
}

model EquipmentType {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  equipments Equipment[]
  
  @@map("equipment_types")
}

model Unit {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  equipments Equipment[]
  
  @@map("units")
}

model FileData {
  fileId   Int      @id @default(autoincrement())
  fileName String
  fileSize Decimal  @db.Decimal(10, 2)
  fileType String
  fileUrl  String

  // เส้นทางกลับสำหรับตรวจสอบว่าไฟล์นี้ถูกใช้ในครุภัณฑ์ไหนบ้าง
  refEquipments Equipment[] @relation("ReferenceDocs")
  attEquipments Equipment[] @relation("AttachFiles")

  @@map("file_data")
}

model Equipment {
  id              Int      @id @default(autoincrement())
  name            String 

  typeId          Int      @map("type_id")
  categoryId      Int      @map("category_id")
  unitId          Int      @map("unit_id")

  brand           String?
  model           String?
  description     String?

  reasonForUse    String   @map("reason_for_use")
  unitPrice       String   @map("unit_price") // ถ้าต้องการคำนวณราคา แนะนำให้เปลี่ยนเป็น Decimal ในอนาคตครับ

  // --- แก้ไขจุดนี้ให้เป็น Int? เพื่อให้ตรงกับ fileId ของ FileData ---
  referenceDocsId Int?     @map("reference_docs_id")
  attachFileId    Int?     @map("attach_file_id")

  createAt        DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // --- Relations ความสัมพันธ์ ---
  type            EquipmentType @relation(fields: [typeId], references: [id])
  category        Category      @relation(fields: [categoryId], references: [id])
  unit            Unit          @relation(fields: [unitId], references: [id])
  
  // สร้างความสัมพันธ์ไปยังตาราง FileData โดยใช้ ID ที่เราเพิ่งเปลี่ยนเป็น Int
  referenceDocs   FileData?     @relation("ReferenceDocs", fields: [referenceDocsId], references: [fileId])
  attachFile      FileData?     @relation("AttachFiles", fields: [attachFileId], references: [fileId])

  @@map("equipments")
}